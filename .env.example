# ─────────────────────────────────────────────────────────────
# NYAY.AI — Environment variables
# Copy to .env.local for local dev. Set these in Vercel for production.
# ─────────────────────────────────────────────────────────────

# Free key at https://console.groq.com (no credit card required)
GROQ_API_KEY=

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# App base URL
# Local:      http://localhost:3000
# Production: https://<your-domain>.vercel.app  (or your custom domain)
NEXTAUTH_URL=

# ─────────────────────────────────────────────────────────────
# DATABASE_URL — PostgreSQL
# ─────────────────────────────────────────────────────────────
# Production (Vercel): use a hosted Postgres provider.
#   Vercel Postgres:  postgres://default:<pw>@<host>-pooler.<region>.aws.neon.tech/verceldb?sslmode=require
#   Neon:             postgresql://<user>:<pw>@<host>.neon.tech/<db>?sslmode=require
#   Supabase:         postgresql://postgres:<pw>@db.<ref>.supabase.co:5432/postgres
#
# Local dev options:
#   - Docker:   postgresql://nyay:nyay@localhost:5432/nyay
#   - Or use the same hosted URL as production (separate database)
#
# After setting this, run:
#   npx prisma generate
#   npx prisma db push
DATABASE_URL=

# RAG System — no API key required
# Run 'npm run generate-embeddings' once after setup to build the vector index.
# The generated src/data/case-embeddings.json should be committed to git.

# Optional Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
